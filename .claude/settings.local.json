  "permissions": {
    "allow": [
      "Read(//Applications/Claude.app/Contents/MacOS/**)",
      "Bash(code:*)",
      "Bash(sudo ln:*)",
      "Bash(echo:*)",
      "Bash(claude --version)",
      "Read(//Applications/Visual Studio Code.app/Contents/Resources/app/bin/**)",
      "Bash(brew install:*)",
      "Bash(bun run check:*)",
