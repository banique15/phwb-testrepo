      "Bash(cat:*)",
      "Bash(pkill:*)",
      "Bash(NODE_ENV=production vite build:*)",
      "Bash(tee:*)",
      "Bash(vite build:*)",
      "Bash(bun run build:*)",
      "Bash(npx svelte-check:*)",
      "Bash(curl:*)",
      "Bash(psql:*)",
      "Bash(bun dev)",
      "Bash(bun add:*)",
      "Bash(lsof:*)",
      "Bash(xargs kill:*)",
      "WebFetch(domain:driverjs.com)"
